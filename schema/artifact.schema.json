{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core AI Catalog Artifact",
  "type": "object",
  "required": [
    "id",
    "group",
    "github",
    "huggingface",
    "officiality"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "group": {
      "type": "string",
      "enum": [
        "zoo",
        "official",
        "external",
        "unknown"
      ]
    },
    "github": {
      "type": "object",
      "required": [
        "owner",
        "repo"
      ],
      "properties": {
        "owner": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "huggingface": {
      "type": "object",
      "required": [
        "owner",
        "repo"
      ],
      "properties": {
        "owner": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "url": {
          "type": "string"
        }
      }
    },
    "officiality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "apple_export_recipe",
        "apple_hosted_artifact",
        "community_packaged"
      ],
      "properties": {
        "apple_export_recipe": {
          "type": "boolean"
        },
        "apple_hosted_artifact": {
          "type": "boolean"
        },
        "community_packaged": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "group": {
            "const": "official"
          }
        }
      },
      "then": {
        "properties": {
          "officiality": {
            "properties": {
              "apple_export_recipe": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "group": {
            "const": "zoo"
          }
        }
      },
      "then": {
        "properties": {
          "officiality": {
            "properties": {
              "apple_export_recipe": {
                "const": false
              }
            }
          }
        }
      }
    }
  ]
}
