{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core AI Catalog Benchmark",
  "description": "Benchmark measurement for a Core AI model. v2 adds optional methodology, device_info, runtime_config, provenance, and environment_state blocks for crowdsourced benchmarks. All new fields are optional — existing v1 entries remain valid.",
  "type": "object",
  "required": [
    "model_id",
    "metric",
    "unit",
    "value",
    "observed",
    "source",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique benchmark ID. Auto-generated for crowdsourced entries."
    },
    "model_id": {
      "type": "string",
      "minLength": 1,
      "description": "Must resolve to a model in catalog.yaml."
    },
    "metric": {
      "type": "string",
      "enum": [
        "decode_throughput",
        "time_to_first_token",
        "prompt_processing_throughput",
        "image_generation_latency",
        "segmentation_latency",
        "transcription_latency",
        "prefill_latency",
        "memory_footprint",
        "inference_latency",
        "inference_fps",
        "realtime_factor",
        "audio_generation_rtf",
        "embedding_throughput"
      ]
    },
    "unit": {
      "type": "string",
      "enum": [
        "tokens_per_second",
        "seconds",
        "seconds_per_image",
        "seconds_per_token",
        "megabytes",
        "milliseconds",
        "frames_per_second",
        "realtime_factor"
      ]
    },
    "value": { "type": ["number", "null", "string"] },
    "device": {
      "type": ["string", "null"],
      "description": "Human-readable device name or coarsened device class (e.g. 'iphone-a18-pro')."
    },
    "compute_unit": {
      "type": ["string", "null"],
      "enum": ["GPU", "ANE", "CPU", "mixed", null]
    },
    "precision": { "type": ["string", "null"] },
    "environment": {
      "type": ["string", "null"],
      "minLength": 1,
      "description": "Free-text environment description (e.g. 'iOS 27.0, coreai-pipelined engine')."
    },
    "observed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date of measurement (date only, no time component)."
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "description": "Provenance source identifier (sources.yaml ref, 'crowdsourced', or upstream ID)."
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "needs_review"]
    },
    "higher_is_better": { "type": "boolean" },
    "superseded_by": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] },

    "methodology": {
      "type": "object",
      "description": "Reproducibility metadata. How the benchmark was measured.",
      "properties": {
        "protocol_version": { "type": "string", "description": "e.g. '1.0'" },
        "prompt_tokens": { "type": ["integer", "null"] },
        "generation_tokens": { "type": ["integer", "null"] },
        "warmup_runs": { "type": ["integer", "null"] },
        "measured_runs": { "type": ["integer", "null"] },
        "statistic": {
          "type": ["string", "null"],
          "enum": ["median", "mean", "max", "min", null]
        },
        "stddev": { "type": ["number", "null"] },
        "p50": { "type": ["number", "null"] },
        "p95": { "type": ["number", "null"] }
      },
      "additionalProperties": false
    },

    "device_info": {
      "type": "object",
      "description": "Coarsened device fingerprint. Exact model is never stored — only the class.",
      "properties": {
        "device_class": {
          "type": "string",
          "description": "Coarsened device class (e.g. 'iphone-a18-pro', 'mac-m4-max')."
        },
        "chip_family": {
          "type": "string",
          "description": "Chip family (e.g. 'A18 Pro', 'M4 Max')."
        },
        "ram_gb": { "type": ["integer", "null"] },
        "os_major_version": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "runtime_config": {
      "type": "object",
      "description": "Exact runtime configuration used for the benchmark.",
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["coreai-pipelined", "coreai-sequential", "coreai", "unknown"]
        },
        "batch_size": { "type": ["integer", "null"] },
        "context_length": { "type": ["integer", "null"] }
      },
      "additionalProperties": false
    },

    "environment_state": {
      "type": "object",
      "description": "Environmental factors that affect performance.",
      "properties": {
        "thermal_state": {
          "type": ["string", "null"],
          "enum": ["nominal", "fair", "serious", "critical", null]
        },
        "low_power_mode": { "type": ["boolean", "null"] },
        "battery_level": {
          "type": ["number", "null"],
          "description": "Coarsened to 0.1 steps (0.0-1.0)."
        },
        "plugged_in": { "type": ["boolean", "null"] }
      },
      "additionalProperties": false
    },

    "model_hash": {
      "type": ["string", "null"],
      "description": "SHA256 of .aimodel bundle contents (weights only, no paths). Used for reproducibility verification."
    },

    "provenance": {
      "type": "object",
      "description": "Full provenance chain for this benchmark.",
      "properties": {
        "source": {
          "type": "string",
          "enum": ["crowdsourced", "manual", "upstream", "derived"]
        },
        "extraction_method": {
          "type": "string",
          "enum": [
            "app_benchmark_protocol",
            "app_benchmark_user_initiated",
            "hf_metadata_api",
            "hf_file_listing",
            "apple_documentation",
            "upstream_readme_scripted",
            "upstream_readme_manual",
            "upstream_release_notes",
            "derived_calculated",
            "community_submission"
          ]
        },
        "device_attestation": {
          "type": "boolean",
          "description": "True if Apple App Attest verified the submission."
        },
        "verification_status": {
          "type": "string",
          "enum": ["accepted", "pending", "quarantined", "rejected"]
        },
        "auto_merged": {
          "type": "boolean",
          "description": "True if auto-merged by GitHub Action (MAD passed + attestation valid)."
        }
      },
      "additionalProperties": false
    }
  }
}
