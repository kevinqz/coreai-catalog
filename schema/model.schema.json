{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core AI Catalog Model",
  "type": "object",
  "required": [
    "id",
    "name",
    "family",
    "source_group",
    "artifact_ref",
    "capabilities",
    "modalities",
    "artifact",
    "size",
    "runtime",
    "device_support",
    "license",
    "status",
    "maturity",
    "confidence",
    "sources",
    "last_verified"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "family": {
      "type": "string"
    },
    "source_group": {
      "type": "string",
      "enum": [
        "zoo",
        "official",
        "external",
        "unknown"
      ]
    },
    "artifact_ref": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "modalities": {
      "type": "object",
      "required": [
        "input",
        "output"
      ]
    },
    "artifact": {
      "type": "object"
    },
    "size": {
      "type": "object"
    },
    "runtime": {
      "type": "object"
    },
    "device_support": {
      "type": "object"
    },
    "license": {
      "type": "object"
    },
    "status": {
      "type": "string"
    },
    "maturity": {
      "type": "string"
    },
    "confidence": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified": {
      "type": "string"
    }
  }
}