{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core AI Catalog Model",
  "type": "object",
  "required": [
    "id",
    "name",
    "family",
    "source_group",
    "capabilities",
    "modalities",
    "artifact",
    "size",
    "runtime",
    "device_support",
    "license",
    "status",
    "maturity",
    "confidence",
    "sources",
    "last_verified"
  ],
  "properties": {
    "id": {"type": "string"},
    "name": {"type": "string"},
    "family": {"type": "string"},
    "source_group": {"type": "string", "enum": ["zoo", "official", "external", "unknown"]},
    "source_path": {"type": ["string", "null"]},
    "capabilities": {"type": "array", "items": {"type": "string"}},
    "modalities": {
      "type": "object",
      "required": ["input", "output"],
      "properties": {
        "input": {"type": "array", "items": {"type": "string"}},
        "output": {"type": "array", "items": {"type": "string"}}
      }
    },
    "artifact": {"type": "object", "required": ["format", "availability"]},
    "size": {"type": "object"},
    "runtime": {"type": "object"},
    "device_support": {"type": "object"},
    "benchmark": {"type": ["object", "null"]},
    "license": {"type": "object"},
    "status": {"type": "string", "enum": ["confirmed", "needs_review", "deprecated", "unknown"]},
    "maturity": {"type": "string", "enum": ["stable", "active", "experimental", "research", "unknown"]},
    "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
    "sources": {"type": "array", "items": {"type": "string"}},
    "last_verified": {"type": "string"},
    "notes": {"type": ["string", "null"]}
  }
}
